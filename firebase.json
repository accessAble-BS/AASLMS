{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/dashboard",
        "destination": "/dashboard.html"
      },
      {
        "source": "/course",
        "destination": "/course.html"
      },
      {
        "source": "/module",
        "destination": "/module.html"
      },
      {
        "source": "/view",
        "destination": "/view.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
